<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/cvHomeProfile">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ARENA FITNESS"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvHomeMemberName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome, Alex."
                        android:textColor="@color/text_black"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cvHomeProfile"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true">
                    <ImageView
                        android:id="@+id/ivHomeProfilePicture"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery" />
                </androidx.cardview.widget.CardView>
            </RelativeLayout>

            <!-- Membership Status Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvMembershipStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/membership_card_bg">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View
                        android:id="@+id/vStatusAccent"
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/membership_accent" />
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">
                        <TextView
                            android:id="@+id/tvStatusLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status keanggotaan"
                            android:textColor="@color/membership_text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />
                        <TextView
                            android:id="@+id/tvMembershipPlanName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Premium Active"
                            android:textColor="@color/text_black"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            app:layout_constraintTop_toBottomOf="@id/tvStatusLabel"
                            app:layout_constraintStart_toStartOf="parent" />

                        <!-- Badge Aktif -->
                        <TextView
                            android:id="@+id/tvStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input_field"
                            android:backgroundTint="@color/membership_badge_bg"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp"
                            android:text="Aktif"
                            android:textColor="@color/membership_badge_text"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="@id/tvMembershipPlanName"
                            app:layout_constraintBottom_toBottomOf="@id/tvMembershipPlanName"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <ProgressBar
                            android:id="@+id/pbMembershipProgress"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="20dp"
                            android:progress="65"
                            android:progressTint="@color/membership_accent"
                            android:progressBackgroundTint="@color/light_gray"
                            app:layout_constraintTop_toBottomOf="@id/tvMembershipPlanName" />

                        <TextView
                            android:id="@+id/tvMembershipExpiryInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Berakhir: 15 Juni 2025 · 55 hari tersisa"
                            android:textColor="@color/membership_text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/pbMembershipProgress"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats Row -->
            <LinearLayout
                android:id="@+id/llStatsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true"
                    app:cardBackgroundColor="@color/membership_card_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kunjungan bulan ini"
                            android:textColor="@color/membership_text_secondary"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvMonthlyVisits"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="@color/text_black"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true"
                    app:cardBackgroundColor="@color/membership_card_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total latihan"
                            android:textColor="@color/membership_text_secondary"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvTotalWorkouts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="47"
                            android:textColor="@color/text_black"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_gray"
                android:layout_marginTop="16dp" />

            <!-- Scheduled Classes Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="SCHEDULED CLASSES"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Limited to approx 3 rows (approx 150dp) and scrollable -->
            <ListView
                android:id="@+id/lvClasses"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="12dp"
                android:divider="@color/dark_gray"
                android:dividerHeight="1dp"
                android:background="@color/white"
                android:nestedScrollingEnabled="true" />

            <!-- Quick Actions Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AKSI CEPAT"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btnQuickCheckIn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/primary_red"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_input_add"
                        app:tint="@color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHECK-IN SEKARANG"
                        android:layout_marginStart="16dp"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Digital ID / QR Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvQrCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/ivQrCode"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@android:drawable/ic_dialog_info" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:id="@+id/tvIdTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DIGITAL MEMBER ID"
                            android:textColor="@color/text_black"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvQrLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scan at gate to enter"
                            android:textSize="12sp"
                            android:textColor="@color/text_gray" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Announcement Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="LAB UPDATES"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cvAnnouncement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/arenafitness" />
                    <TextView
                        android:id="@+id/tvAnnContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="Loading updates..."
                        android:textColor="@color/text_black"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvAnnDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp"
                        android:text=""
                        android:textColor="@color/text_gray"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/nav_background_light"
        app:itemIconTint="@color/primary_red"
        app:itemTextColor="@color/text_black"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>